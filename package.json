{
  "name": "lzt-element-image-preview",
  "version": "2.1.1",
  "private": false,
  "description": "基于 Element ui 封装的图片预览功能组件",
  "main": "dist/lzt-element-image-preview.umd.js",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luzhaotian/element-image-preview.git"
  },
  "bugs": {
    "url": "https://github.com/Luzhaotian/element-image-preview/issues"
  },
  "homepage": "https://luzhaotian.github.io/element-image-preview/",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "element",
    "image",
    "preview"
  ],
  "peerDependencies": {
    "vue": "^2.6.0"
  },
  "scripts": {
    "serve": "npm run sync-pdf-worker && vue-cli-service serve",
    "sync-pdf-worker": "node scripts/copy-pdf-worker.js",
    "build": "npm run sync-pdf-worker && vue-cli-service build",
    "format": "prettier --write \"**/*.{js,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,vue,json,css,scss,md}\"",
    "lint": "vue-cli-service lint",
    "lib": "vue-cli-service build --target lib packages/index.js",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org/ --access public",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "prettier --write",
      "vue-cli-service lint"
    ],
    "*.{json,css,scss,md}": "prettier --write"
  },
  "dependencies": {
    "pdfjs-dist": "^4.6.82",
    "throttle-debounce": "^1.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "core-js": "^3.8.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-vue": "^8.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "sass": "^1.69.4",
    "sass-loader": "^13.3.2",
    "vue": "^2.6.14",
    "vue-template-compiler": "^2.6.14"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "eslintIgnore": [
    "dist",
    "node_modules",
    "scripts"
  ]
}
